#!/bin/zsh
# cmux-n8n: n8n 워크플로우 개발 레이아웃
# +-------------------+----------------------+
# | Claude (터미널)   | n8n UI (브라우저)    |
# |                   | localhost:<port>     |
# +-------------------+----------------------+
#
# 사용법: cmux-n8n [포트]  (기본: 5678)

set -euo pipefail

if ! command -v cmux &>/dev/null; then
  echo "Error: cmux CLI를 찾을 수 없습니다. cmux.app이 설치되어 있는지 확인하세요."
  exit 1
fi

if [[ -z "${CMUX_WORKSPACE_ID:-}" ]]; then
  echo "Error: cmux workspace 터미널 안에서 실행해주세요."
  exit 1
fi

CURRENT_PANES=$(cmux list-panes 2>/dev/null | grep -cE "pane:[0-9]+" || true)
if [[ "$CURRENT_PANES" -gt 1 ]]; then
  echo "이미 $CURRENT_PANES 개의 pane이 있습니다."
  exit 1
fi

N8N_PORT="${1:-5678}"
echo "n8n 레이아웃 설정 중... (포트: $N8N_PORT)"

# 오른쪽에 브라우저 pane (n8n UI)
cmux new-pane --type browser --direction right --url "http://localhost:$N8N_PORT"

cmux set-status layout "n8n+browser" --icon "arrow.triangle.branch" --color "#E65100"
echo "완료. 우측에 n8n UI 브라우저가 열립니다."
echo "n8n이 실행 중이지 않으면 먼저 n8n 서버를 시작해주세요."
