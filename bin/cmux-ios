#!/bin/zsh
# cmux-ios: iOS 개발 3-pane 레이아웃 + claude 자동 시작
# +-------------------+----------+
# | main (현재)       | sub-top  |  ← claude 자동시작
# |   Claude 유지     +----------+
# |                   | sub-bot  |  ← claude 자동시작
# +-------------------+----------+
#
# 사용법: cmux-ios [프로젝트-디렉토리]
# NOTE: zsh 1-indexed arrays used throughout

set -euo pipefail

if ! command -v cmux &>/dev/null; then
  echo "Error: cmux CLI를 찾을 수 없습니다. cmux.app이 설치되어 있는지 확인하세요."
  exit 1
fi

if [[ -z "${CMUX_WORKSPACE_ID:-}" ]]; then
  echo "Error: cmux workspace 터미널 안에서 실행해주세요."
  exit 1
fi

CURRENT_PANES=$(cmux list-panes 2>/dev/null | grep -cE "pane:[0-9]+" || true)
if [[ "$CURRENT_PANES" -gt 1 ]]; then
  echo "이미 $CURRENT_PANES 개의 pane이 있습니다. 초기화하려면 기존 pane을 닫아주세요."
  exit 1
fi

CWD="${1:-$PWD}"

if [[ ! -d "$CWD" ]]; then
  echo "Warning: 디렉토리가 존재하지 않습니다: $CWD"
fi

echo "iOS 3-pane 레이아웃 설정 중... ($CWD)"

# printf %q 로 경로 안전하게 이스케이프
CWD_Q=$(printf '%q' "$CWD")

# 오른쪽 상단 pane → claude 자동 시작
RT_OUT=$(cmux new-pane --direction right)
RT_SURFACE=$(echo "$RT_OUT" | grep -oE "surface:[0-9]+" | head -1)
if [[ -z "$RT_SURFACE" ]]; then
  echo "Error: 오른쪽 상단 pane surface ID를 파악할 수 없습니다."
  exit 1
fi
cmux send --surface "$RT_SURFACE" "cd $CWD_Q && claude"$'\n'

# 오른쪽 하단 pane → claude 자동 시작
RB_OUT=$(cmux new-pane --direction down)
RB_SURFACE=$(echo "$RB_OUT" | grep -oE "surface:[0-9]+" | head -1)
if [[ -z "$RB_SURFACE" ]]; then
  echo "Error: 오른쪽 하단 pane surface ID를 파악할 수 없습니다."
  exit 1
fi
cmux send --surface "$RB_SURFACE" "cd $CWD_Q && claude"$'\n'

cmux set-status layout "ios-3pane" --icon "rectangle.split.3x1" --color "#1565C0"
echo "완료. 우상단/우하단 pane에서 claude가 시작됩니다."
