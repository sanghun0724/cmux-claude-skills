#!/usr/bin/env zsh
# cmux-colorize: pane 그룹별 터미널 배경색 변경 (ANSI OSC 11)
#
# 동작 방식:
#   각 pane의 surface 제목을 classify해서 그룹(work/research/tools)을 결정하고,
#   첫 번째 쉘 surface에 'printf \033]11;#color\007' 명령을 전송합니다.
#
# ⚠️  주의: 쉘 프롬프트 상태인 surface에서만 동작합니다.
#           Claude/Python REPL 등 실행 중인 surface는 건너뜁니다.
#
# 사용법: cmux-colorize [workspace-ref]
#
# 환경변수:
#   CMUX_COLOR_WORK      작업 pane 배경색 (기본: #0d1117)
#   CMUX_COLOR_RESEARCH  리서치 pane 배경색 (기본: #0a1628)
#   CMUX_COLOR_TOOLS     도구 pane 배경색 (기본: #1a0d28)
#   CMUX_RESEARCH_KEYWORDS  리서치 분류 키워드 (파이프 구분 정규식)
#   CMUX_TOOLS_KEYWORDS     도구 분류 키워드 (파이프 구분 정규식)

set -euo pipefail

if ! command -v cmux &>/dev/null; then
  echo "Error: cmux CLI를 찾을 수 없습니다. cmux.app이 설치되어 있는지 확인하세요."
  exit 1
fi

WORKSPACE="${1:-${CMUX_WORKSPACE_ID:-}}"
if [[ -z "$WORKSPACE" ]]; then
  echo "Usage: cmux-colorize [workspace-ref]"
  echo "  또는 cmux 워크스페이스 터미널 안에서 실행하세요 (CMUX_WORKSPACE_ID 자동 설정)."
  exit 1
fi

# ── 색상 설정 ────────────────────────────────────────────────
COLOR_WORK="${CMUX_COLOR_WORK:-#0d1117}"
COLOR_RESEARCH="${CMUX_COLOR_RESEARCH:-#0a1628}"
COLOR_TOOLS="${CMUX_COLOR_TOOLS:-#1a0d28}"

# ── 분류 패턴 ────────────────────────────────────────────────
_RESEARCH_PAT="${CMUX_RESEARCH_KEYWORDS:-리서치|research|deep.dive|지식|저장소|survey|분석|조사}"
_TOOLS_PAT="${CMUX_TOOLS_KEYWORDS:-skill|스킬|rule|obsidian|consistency|hook|plugin|setup|도구|n8n|claude|hud|memory}"

classify_surface() {
  local title
  title=$(echo "$1" | tr '[:upper:]' '[:lower:]')
  if echo "$title" | grep -qE "$_RESEARCH_PAT"; then
    echo "research"
  elif echo "$title" | grep -qE "$_TOOLS_PAT"; then
    echo "tools"
  else
    echo "work"
  fi
}

# Claude 실행 중 감지 (✳ ⠂ ⠐ 접두사)
is_claude_running() {
  echo "$1" | grep -qE "^[✳⠂⠐]"
}

apply_color() {
  local surface=$1 color=$2
  # OSC 11: 터미널 배경색 변경. printf 명령을 쉘에서 실행.
  local err
  err=$(cmux send --surface "$surface" "printf '\\033]11;${color}\\007'"$'\n' 2>&1) || {
    echo "  Warning: $surface 에 전송 실패 — $err"
    return 0
  }
}

echo "=== cmux-colorize: $WORKSPACE ==="

while IFS= read -r pane_line; do
  PANE=$(echo "$pane_line" | grep -oE "pane:[0-9]+" | head -1)
  [[ -z "$PANE" ]] && continue

  # 이 pane의 surface 목록 수집 및 분류
  declare -a GROUPS=()
  SHELL_SURFACE=""   # Claude 미실행 surface (쉘 프롬프트 상태)

  while IFS= read -r surf_line; do
    [[ -z "$surf_line" ]] && continue
    SURFACE=$(echo "$surf_line" | grep -oE "surface:[0-9]+" | head -1)
    [[ -z "$SURFACE" ]] && continue
    TITLE=$(echo "$surf_line" | sed -E 's/[* ]*(surface:[0-9]+)[[:space:]]*//' \
            | sed 's/\[selected\]//' | xargs)

    GROUPS+=("$(classify_surface "$TITLE")")

    # [selected] surface와 Claude 실행 중 surface 건너뜀
    local is_selected=false
    echo "$surf_line" | grep -q "\[selected\]" && is_selected=true

    if [[ -z "$SHELL_SURFACE" ]] && [[ "$is_selected" == false ]] && ! is_claude_running "$TITLE"; then
      SHELL_SURFACE="$SURFACE"
    fi
  done < <(cmux list-pane-surfaces --workspace "$WORKSPACE" --pane "$PANE" 2>/dev/null)

  [[ ${#GROUPS[@]} -eq 0 ]] && continue

  # 다수결로 pane 그룹 결정
  local_work=$(printf '%s\n' "${GROUPS[@]}" | grep -c "^work$" || true)
  local_research=$(printf '%s\n' "${GROUPS[@]}" | grep -c "^research$" || true)
  local_tools=$(printf '%s\n' "${GROUPS[@]}" | grep -c "^tools$" || true)

  if [[ $local_research -gt $local_work && $local_research -gt $local_tools ]]; then
    PANE_GROUP="research"; COLOR="$COLOR_RESEARCH"
  elif [[ $local_tools -gt $local_work ]]; then
    PANE_GROUP="tools";    COLOR="$COLOR_TOOLS"
  else
    PANE_GROUP="work";     COLOR="$COLOR_WORK"
  fi

  if [[ -n "$SHELL_SURFACE" ]]; then
    printf "  %-12s → [%-8s] %s\n" "$PANE" "$PANE_GROUP" "$COLOR"
    apply_color "$SHELL_SURFACE" "$COLOR"
    sleep 0.1
  else
    printf "  %-12s → [%-8s] %s  (건너뜀: 모든 surface가 실행 중)\n" "$PANE" "$PANE_GROUP" "$COLOR"
  fi

  unset GROUPS SHELL_SURFACE
done < <(cmux list-panes --workspace "$WORKSPACE" 2>/dev/null | grep "pane:")

echo ""
echo "완료. 배경색이 적용되지 않은 pane은 쉘 프롬프트 상태의 surface가 없는 것입니다."
echo "  색상 커스터마이즈: CMUX_COLOR_WORK / CMUX_COLOR_RESEARCH / CMUX_COLOR_TOOLS"
