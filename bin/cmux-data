#!/bin/zsh
# cmux-data: 데이터 분석 레이아웃 (claude 위 + Python REPL 아래)
# +----------------------------------+
# | Claude (위 60%)                  |
# +----------------------------------+
# | Python REPL (아래 40%)           |  ← python3 자동 시작
# +----------------------------------+
#
# 사용법: cmux-data

set -euo pipefail

if ! command -v cmux &>/dev/null; then
  echo "Error: cmux CLI를 찾을 수 없습니다. cmux.app이 설치되어 있는지 확인하세요."
  exit 1
fi

if [[ -z "${CMUX_WORKSPACE_ID:-}" ]]; then
  echo "Error: cmux workspace 터미널 안에서 실행해주세요."
  exit 1
fi

if ! command -v python3 &>/dev/null; then
  echo "Warning: python3를 찾을 수 없습니다. REPL 자동 시작을 건너뜁니다."
fi

CURRENT_PANES=$(cmux list-panes 2>/dev/null | grep -cE "pane:[0-9]+" || true)
if [[ "$CURRENT_PANES" -gt 1 ]]; then
  echo "이미 $CURRENT_PANES 개의 pane이 있습니다."
  exit 1
fi

echo "데이터 분석 레이아웃 설정 중..."

# 아래에 Python REPL pane → python3 자동 시작
BOT=$(cmux new-pane --direction down)
BOT_SURFACE=$(echo "$BOT" | grep -oE "surface:[0-9]+" | head -1)
if [[ -z "$BOT_SURFACE" ]]; then
  echo "Error: 하단 pane surface ID를 파악할 수 없습니다."
  exit 1
fi

if command -v python3 &>/dev/null; then
  cmux send --surface "$BOT_SURFACE" "python3\n"
fi

cmux set-status layout "data+python" --icon "chart.bar" --color "#2E7D32"
echo "완료. 아래 pane에서 python3 REPL이 시작됩니다."
