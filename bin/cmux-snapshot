#!/usr/bin/env python3
"""cmux-snapshot: 현재 cmux 레이아웃 + Claude 세션 ID를 JSON 스냅샷으로 저장
사용법: cmux-snapshot [snapshot-name]
  snapshot-name 기본값: "latest" (항상 덮어씀)

환경 요구사항:
  - macOS + cmux.app 설치
  - Claude Code CLI 사용 시 ~/.claude/projects/ 에 세션 인덱스 존재

세션 ID 매핑 우선순위 (self-healing):
  1. 살아있는 claude 프로세스의 --session-id + CMUX_SURFACE_ID env (정확도 100%)
  2. ~/.cmux-snapshots/session-map.jsonl (SessionStart hook 영구 적립, 죽은 세션 포함)
  3. fuzzy fallback — sessions-index.json + jsonl 직접 스캔 (제목/프롬프트 매칭)
"""

import json
import os
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path

SESSION_JSON = Path(
    os.environ.get(
        "CMUX_SESSION_FILE",
        str(Path.home() / "Library/Application Support/cmux/session-com.cmuxterm.app.json"),
    )
)
SNAPSHOT_DIR = Path(os.environ.get("CMUX_SNAPSHOT_DIR", str(Path.home() / ".cmux-snapshots")))
CLAUDE_PROJECTS = Path(os.environ.get("CMUX_CLAUDE_PROJECTS", str(Path.home() / ".claude/projects")))

UUID_RE = re.compile(r"[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}")

# {panel_uuid_upper: claude_session_id} — main()에서 채워짐
LIVE_SESSIONS: dict = {}


def discover_persisted_sessions() -> dict:
    """session-map.jsonl에서 panel UUID -> session ID 영구 매핑을 읽습니다.

    Hook(cmux-snapshot-track)으로 적립된 영구 매핑. 죽은 세션도 추적 가능.
    같은 panel에 여러 매핑이 있으면 가장 최근 ts 우선.
    returns: {panel_uuid_upper: session_id}
    """
    log = SNAPSHOT_DIR / "session-map.jsonl"
    if not log.exists():
        return {}
    latest: dict = {}  # panel -> (ts, sid)
    try:
        with open(log) as f:
            for line in f:
                try:
                    r = json.loads(line)
                except (json.JSONDecodeError, ValueError):
                    continue
                p = r.get("panel")
                s = r.get("session")
                ts = r.get("ts", "")
                if not (p and s):
                    continue
                cur = latest.get(p)
                if not cur or ts > cur[0]:
                    latest[p] = (ts, s)
    except OSError:
        return {}
    return {p.upper(): v[1] for p, v in latest.items()}


def discover_live_sessions() -> dict:
    """ps 기반으로 살아있는 claude 프로세스의 panel UUID -> session ID 매핑을 추출합니다.

    `ps -eo pid,command`로 `--session-id <UUID>` 추출 + `ps -E -p <pid>`로
    CMUX_SURFACE_ID 환경변수 추출 → panel UUID와 sessionId의 100% 정확한 매핑.
    returns: {panel_uuid_upper: session_id}
    """
    mapping: dict = {}
    try:
        out = subprocess.run(
            ["ps", "-eo", "pid,command"],
            capture_output=True,
            text=True,
            timeout=5,
        ).stdout
    except (subprocess.SubprocessError, OSError):
        return mapping

    for line in out.splitlines():
        m = re.search(r"--session-id\s+(" + UUID_RE.pattern + r")", line)
        if not m:
            continue
        sid = m.group(1).lower()
        toks = line.strip().split()
        if not toks:
            continue
        pid = toks[0]
        if not pid.isdigit():
            continue
        try:
            env = subprocess.run(
                ["ps", "-E", "-p", pid],
                capture_output=True,
                text=True,
                timeout=3,
            ).stdout
        except (subprocess.SubprocessError, OSError):
            continue
        sm = re.search(r"CMUX_SURFACE_ID=(" + UUID_RE.pattern + r")", env)
        if sm:
            mapping[sm.group(1).upper()] = sid
    return mapping


def project_dir_for(cwd: str) -> Path | None:
    """cwd → ~/.claude/projects 키 (모든 non-alphanumeric을 '-'로 치환).

    예: '/Users/brady/Library/Mobile Documents/iCloud~md~obsidian/...'
        → '-Users-brady-Library-Mobile-Documents-iCloud-md-obsidian-...'
    실제로 존재하는 경우에만 Path 반환.
    """
    if not cwd:
        return None
    key = re.sub(r"[^A-Za-z0-9]+", "-", cwd)
    if not key.startswith("-"):
        key = "-" + key
    p = CLAUDE_PROJECTS / key
    return p if p.exists() else None


def extract_first_prompt(jsonl_path: Path) -> str | None:
    """jsonl에서 첫 user 텍스트 메시지 추출 (slash 명령이나 <tag>로 시작하는 것은 제외)."""
    try:
        with open(jsonl_path) as f:
            for line in f:
                try:
                    o = json.loads(line)
                except (json.JSONDecodeError, ValueError):
                    continue
                if o.get("type") != "user":
                    continue
                msg = o.get("message", {}).get("content", "")
                if isinstance(msg, list):
                    for c in msg:
                        if isinstance(c, dict) and c.get("type") == "text":
                            msg = c.get("text", "")
                            break
                    else:
                        continue
                if isinstance(msg, str) and msg and not msg.lstrip().startswith("<"):
                    return msg.strip()
    except OSError:
        return None
    return None


def _score_text(title_lower: str, text: str) -> int:
    text = (text or "").lower()
    if not text:
        return 0
    if title_lower in text or text in title_lower:
        return 3
    if any(w in text for w in title_lower.split() if len(w) > 2):
        return 1
    return 0


def _find_in_index(index_path: Path, title_lower: str) -> tuple[str | None, str | None, str | None]:
    """sessions-index.json에서 매칭. fullPath가 실존하는 후보만 반환."""
    if not index_path.exists():
        return None, None, None
    try:
        with open(index_path) as f:
            entries = json.load(f).get("entries", [])
    except (json.JSONDecodeError, OSError):
        return None, None, None

    def s(e):
        return max(
            _score_text(title_lower, e.get("summary", "")),
            _score_text(title_lower, e.get("firstPrompt", "")),
        )

    candidates = [e for e in entries if Path(e.get("fullPath", "")).exists()]
    if not candidates:
        return None, None, None
    candidates.sort(key=lambda e: (s(e), e.get("modified", "")), reverse=True)
    best = candidates[0]
    if s(best) <= 0:
        return None, None, None
    return best["sessionId"], best.get("fullPath"), (best.get("firstPrompt") or "")[:120]


def _find_in_files(project_dir: Path, title_lower: str) -> tuple[str | None, str | None, str | None]:
    """*.jsonl 직접 스캔으로 매칭 (인덱스 stale 대비 fallback)."""
    if not project_dir or not project_dir.exists():
        return None, None, None
    files = sorted(project_dir.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
    best: tuple[int, float, Path | None] = (0, 0.0, None)
    prompts: dict[Path, str] = {}
    for fp in files:
        prompt = extract_first_prompt(fp) or ""
        prompts[fp] = prompt
        sc = _score_text(title_lower, prompt)
        if sc > best[0] or (sc == best[0] and fp.stat().st_mtime > best[1]):
            if sc > 0:
                best = (sc, fp.stat().st_mtime, fp)
    if not best[2]:
        return None, None, None
    chosen = best[2]
    return chosen.stem, str(chosen), (prompts.get(chosen, "") or "")[:120]


def find_session(surface_title: str, cwd: str) -> tuple[str | None, str | None, str | None]:
    """surface 제목 + CWD로 (session_id, full_path, first_prompt) 탐색.

    1순위: CWD 프로젝트의 sessions-index.json — fullPath 존재 검증
    2순위: CWD 프로젝트의 *.jsonl 직접 스캔 (mtime 내림차순, prompt 매칭)
    3순위: 전체 인덱스 (파일 존재 검증)
    """
    clean = re.sub(r"^[✳⠂⠐\s]+", "", surface_title or "").strip()
    if not clean:
        return None, None, None
    title_lower = clean.lower()

    proj = project_dir_for(cwd)
    if proj:
        sid, fp, prompt = _find_in_index(proj / "sessions-index.json", title_lower)
        if sid:
            return sid, fp, prompt
        sid, fp, prompt = _find_in_files(proj, title_lower)
        if sid:
            return sid, fp, prompt

    best: tuple[int, str, str | None, str | None, str | None] = (0, "", None, None, None)
    for index_path in CLAUDE_PROJECTS.glob("*/sessions-index.json"):
        try:
            with open(index_path) as f:
                entries = json.load(f).get("entries", [])
        except (json.JSONDecodeError, OSError):
            continue
        for e in entries:
            if not Path(e.get("fullPath", "")).exists():
                continue
            sc = max(
                _score_text(title_lower, e.get("summary", "")),
                _score_text(title_lower, e.get("firstPrompt", "")),
            )
            if sc <= 0:
                continue
            mod = e.get("modified", "")
            if (sc, mod) > (best[0], best[1]):
                best = (sc, mod, e["sessionId"], e.get("fullPath"), (e.get("firstPrompt") or "")[:120])
    if best[2]:
        return best[2], best[3], best[4]
    return None, None, None


# 기존 시그니처와의 호환성 유지를 위한 thin wrapper
def find_session_id(surface_title: str, cwd: str) -> str | None:
    """기존 호환: session_id만 반환."""
    sid, _, _ = find_session(surface_title, cwd)
    return sid


def build_layout(node, panels_by_id):
    node_type = node.get("type")

    if node_type == "pane":
        surfaces = []
        for pid in node["pane"].get("panelIds", []):
            p = panels_by_id.get(pid)
            if not p:
                continue
            title = p.get("title", "")
            is_claude = any(c in title for c in ["✳", "⠂", "⠐"])
            cwd = p.get("directory") or p.get("terminal", {}).get("workingDirectory", "")

            session_id: str | None = None
            full_path: str | None = None
            first_prompt: str | None = None

            # 1순위: live + persisted 매핑 (panel UUID 기반, 100% 정확)
            mapped_sid = LIVE_SESSIONS.get(pid.upper())
            if mapped_sid:
                session_id = mapped_sid
                proj = project_dir_for(cwd)
                if proj:
                    candidate = proj / f"{mapped_sid}.jsonl"
                    if candidate.exists():
                        full_path = str(candidate)
                        first_prompt = (extract_first_prompt(candidate) or "")[:120] or None
                is_claude = True
            elif is_claude:
                # 2순위: fuzzy fallback (죽은 세션이거나 매핑 없을 때)
                session_id, full_path, first_prompt = find_session(title, cwd)

            surfaces.append(
                {
                    "title": title,
                    "dir": cwd,
                    "is_claude": is_claude,
                    "session_id": session_id,
                    "full_path": full_path,
                    "first_prompt": first_prompt,
                }
            )
        return {"type": "pane", "surfaces": surfaces}

    elif node_type == "split":
        s = node["split"]
        return {
            "type": "split",
            "orientation": s.get("orientation", "horizontal"),
            "ratio": round(s.get("dividerPosition", 0.5), 3),
            "first": build_layout(s["first"], panels_by_id),
            "second": build_layout(s["second"], panels_by_id),
        }

    return {"type": "unknown"}


def count(node, what):
    if node["type"] == "pane":
        return 1 if what == "panes" else len(node.get("surfaces", []))
    if node["type"] == "split":
        return count(node["first"], what) + count(node["second"], what)
    return 0  # "unknown" 노드는 0으로 처리


def main():
    raw_name = sys.argv[1] if len(sys.argv) > 1 else "latest"
    # path traversal 방지: 파일명만 허용
    if not re.fullmatch(r"[A-Za-z0-9._\-]+", raw_name):
        print(f"Error: 스냅샷 이름에 허용되지 않는 문자가 있습니다: {raw_name!r}")
        sys.exit(1)
    name = raw_name
    SNAPSHOT_DIR.mkdir(exist_ok=True)
    out = SNAPSHOT_DIR / f"{name}.json"

    if not SESSION_JSON.exists():
        print(f"Error: cmux 세션 파일을 찾을 수 없습니다: {SESSION_JSON}")
        print("cmux.app이 실행 중인지 확인하세요.")
        sys.exit(1)

    try:
        with open(SESSION_JSON) as f:
            session = json.load(f)
    except (json.JSONDecodeError, OSError) as e:
        print(f"Error: 세션 파일 파싱 실패: {e}")
        sys.exit(1)

    global LIVE_SESSIONS
    persisted = discover_persisted_sessions()  # 영구 매핑 (죽은 세션 포함)
    live = discover_live_sessions()  # 현재 살아있는 매핑 (정확도 최상)
    LIVE_SESSIONS = {**persisted, **live}  # live가 우선
    if live or persisted:
        print(f"✓ 세션 매핑: live={len(live)} persisted={len(persisted)} total={len(LIVE_SESSIONS)}")

    snapshot = {
        "version": 2,
        "timestamp": datetime.now().isoformat(),
        "name": name,
        "workspaces": [],
    }

    for window in session.get("windows", []):
        for ws in window.get("tabManager", {}).get("workspaces", []):
            ws_name = ws.get("customTitle") or ws.get("processTitle", "unnamed")
            ws_cwd = ws.get("currentDirectory", "")
            panels_by_id = {p["id"]: p for p in ws.get("panels", [])}
            layout = build_layout(
                ws.get("layout", {"type": "pane", "pane": {"panelIds": []}}),
                panels_by_id,
            )
            snapshot["workspaces"].append(
                {"name": ws_name, "cwd": ws_cwd, "layout": layout}
            )

    with open(out, "w") as f:
        json.dump(snapshot, f, ensure_ascii=False, indent=2)

    print(f"✓ 스냅샷 저장: {out}")
    for ws in snapshot["workspaces"]:
        panes = count(ws["layout"], "panes")
        surfs = count(ws["layout"], "surfaces")

        def claude_count(node):
            if node["type"] == "pane":
                return sum(1 for s in node["surfaces"] if s["is_claude"])
            return claude_count(node["first"]) + claude_count(node["second"])

        def session_count(node):
            if node["type"] == "pane":
                return sum(1 for s in node["surfaces"] if s.get("session_id"))
            return session_count(node["first"]) + session_count(node["second"])

        claudes = claude_count(ws["layout"])
        sessions = session_count(ws["layout"])
        extra = f", Claude {claudes}개 (세션ID 매칭 {sessions}개)" if claudes else ""
        print(f"  {ws['name']}: {panes} panes, {surfs} surfaces{extra}")


if __name__ == "__main__":
    main()
