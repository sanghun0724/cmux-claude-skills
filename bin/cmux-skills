#!/usr/bin/env zsh
# cmux-skills: Claude 스킬/플러그인 개발 레이아웃
# +-------------------+----------+
# | Claude (70%)      | ls / grep|
# |  스킬 설계        | 파일확인 |
# +-------------------+----------+
#
# 사용법: cmux-skills [스킬-디렉토리]  (기본: ~/.claude)

set -euo pipefail

if ! command -v cmux &>/dev/null; then
  echo "Error: cmux CLI를 찾을 수 없습니다. cmux.app이 설치되어 있는지 확인하세요."
  exit 1
fi

if [[ -z "${CMUX_WORKSPACE_ID:-}" ]]; then
  echo "Error: cmux workspace 터미널 안에서 실행해주세요."
  exit 1
fi

CURRENT_PANES=$(cmux list-panes 2>/dev/null | grep -cE "pane:[0-9]+" || true)
if [[ "$CURRENT_PANES" -gt 1 ]]; then
  echo "이미 $CURRENT_PANES 개의 pane이 있습니다."
  exit 1
fi

SKILLS_DIR="${1:-$HOME/.claude}"
echo "스킬 개발 레이아웃 설정 중... ($SKILLS_DIR)"

if [[ ! -d "$SKILLS_DIR" ]]; then
  echo "Warning: 디렉토리가 존재하지 않습니다: $SKILLS_DIR"
fi

SKILLS_DIR_Q=$(printf '%q' "$SKILLS_DIR")

# 오른쪽에 파일 탐색 pane
RT_OUT=$(cmux new-pane --direction right)
RT_SURFACE=$(echo "$RT_OUT" | grep -oE "surface:[0-9]+" | head -1)
if [[ -z "$RT_SURFACE" ]]; then
  echo "Error: 오른쪽 pane surface ID를 파악할 수 없습니다."
  exit 1
fi
cmux send --surface "$RT_SURFACE" "cd $SKILLS_DIR_Q && ls -la"$'\n'

cmux set-status layout "skills+nav" --icon "wand.and.stars" --color "#6A1B9A"
echo "완료. 우측 pane에서 스킬 디렉토리가 열립니다."
